{
  "extends": "./node_modules/@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "types": ["jest", "node"]
  },
  "include": [
    "**/*.ts", 
    "**/*.tsx",
    "declarations.d.ts"
  ],
  "exclude": ["**/node_modules", "**/Pods"]
}

